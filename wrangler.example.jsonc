{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "notion",
  "main": "src/index.ts",
  "compatibility_date": "2025-08-01",
  "account_id": "",
  "workers_dev": false,
  "dev": {
    "ip": "0.0.0.0",
    "port": 1
  },
  "route": {
    "pattern": "notion.example.com/*",
    "zone_name": "example.com",
  },
  "vars": {
    "KEY": "",
    "NOTION_TOKEN": "",
    "ORIGIN_ALLOW": ""
  }
}